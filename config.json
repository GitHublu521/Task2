{
    "seed": 42,
    "subset_size": 5000,
    "batch_size": 128,
    "num_workers": 2,

    "task1": {
        "description": "Weight Initialization Ablation",
        "num_layers": 20,
        "hidden_dim": 256,
        "epochs": 20,
        "lr": 0.001,
        "init_methods": ["default", "xavier_uniform", "xavier_normal", "kaiming_uniform", "kaiming_normal"]
    },

    "task2": {
        "description": "Regularization Ablation",
        "epochs": 30,
        "lr": 0.001
    },

    "task3": {
        "description": "BatchNorm Ablation",
        "epochs": 30,
        "lr": 0.001,
        "configs": [
            {"name": "SimpleCNN (no BN)", "use_bn": false},
            {"name": "DeeperCNN (no BN)", "use_bn": false},
            {"name": "DeeperCNN (with BN)", "use_bn": true}
        ]
    },

    "task4": {
        "description": "Robustness to Distribution Shift",
        "epochs": 30,
        "lr": 0.001,
        "cifar10c_path": "data/CIFAR-10-C",
        "all_corruptions": ["gaussian_noise", "shot_noise", "impulse_noise", "defocus_blur", "glass_blur",
                            "motion_blur", "zoom_blur", "snow", "frost", "fog",
                            "brightness", "contrast", "elastic_transform", "pixelate", "jpeg_compression"],
        "corruptions": ["gaussian_noise", "frost", "brightness"],
        "severities": [1, 3, 5]
    },

    "task5": {
        "description": "Hyperparameter Search with Optuna",
        "n_trials": 20,
        "epochs_per_trial": 10,
        "final_epochs": 30,
        "lr_range": [1e-5, 1e-1],
        "weight_decay_range": [1e-6, 1e-2],
        "dropout_range": [0.0, 0.5],
        "batch_size_choices": [32, 64, 128, 256]
    }
}
